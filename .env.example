# Required — your Anthropic API key (Claude Opus 4.8 access)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — NCBI E-utilities compliance metadata for PubMed lookup.
# Requests work without these, but providing them is the polite, rate-limit-friendly way.
NCBI_TOOL=TrialMind
NCBI_EMAIL=you@example.com

# Optional — force the clearly-labeled cached demo stream instead of calling the live API.
# Useful as a presentation fallback when network/API latency is a risk.
# TRIALMIND_DEMO_MODE=1
